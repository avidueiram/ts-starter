{
  "name": "ts-starter",
  "version": "1.0.0",
  "main": "build/index.js",
  "scripts": {
    "lint": "eslint 'src/**'",
    "build:local": "npm run set-env:local && tsc",
    "build:prod": "npm run set-env:prod && tsc",
    "set-env:local": "cp -f src/environments/environment.local.ts src/environments/environment.ts",
    "set-env:prod": "cp -f src/environments/environment.prod.ts src/environments/environment.ts",
    "start:local": "npm run build:local && LOCAL_LOGS=true node build/index.js",
    "start:prod": "npm run build:prod && node build/index.js"
  },
  "keywords": [],
  "author": "Alfredo Vidueira",
  "engines": {
    "node": "22"
  },
  "license": "Apache-2.0",
  "description": "Typescript starter project",
  "dependencies": {
    "@date-fns/tz": "1.5.0",
    "@google-cloud/error-reporting": "3.0.6",
    "@google-cloud/pubsub": "5.3.1",
    "@google-cloud/storage": "7.21.0",
    "@lukeed/uuid": "2.0.1",
    "@ngneat/falso": "8.0.2",
    "axios": "1.18.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "dotenv": "17.4.2",
    "express": "4.22.2",
    "fecha": "4.2.3",
    "firebase-admin": "13.10.0",
    "firebase-functions": "7.2.5",
    "google-auth-library": "10.7.0",
    "handlebars": "4.7.9",
    "helmet": "8.2.0",
    "neverthrow": "8.2.0",
    "puppeteer-core": "24.43.1",
    "safe-stable-stringify": "2.5.0",
    "validator": "13.15.35",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "3.1.0",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "4.17.21",
    "@types/node": "22.20.0",
    "@types/validator": "13.15.10",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "eslint": "9.39.4",
    "eslint-config-google": "0.14.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-import-newlines": "1.4.1",
    "eslint-plugin-sort-keys": "2.3.5",
    "ts-node": "10.9.2",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0"
  }
}
